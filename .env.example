# ── Supabase (obrigatório) ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key

# ── Provedores de IA (opcionais — sem eles o motor local assume) ──
# Anthropic (Claude) — melhor qualidade de geração
ANTHROPIC_API_KEY=
# OpenRouter — alternativa/fallback
OPENROUTER_API_KEY=

# Limite de gerações por sessão anônima/hora no servidor (default 20)
GENERATION_RATE_LIMIT=20

# ── Owner bypass ────────────────────────────────────────────────
# Emails (separados por vírgula) com acesso total a Pro/Team sem limites.
# O role 'owner' em profiles tem o mesmo efeito (ver migração 0002).
OWNER_EMAIL=augustodutra@gmail.com
NEXT_PUBLIC_OWNER_EMAIL=augustodutra@gmail.com

# URL pública do app (usada em links de compartilhamento)
NEXT_PUBLIC_APP_URL=http://localhost:3000
